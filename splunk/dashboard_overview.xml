<dashboard version="1.1">
  <label>ProxyLogon - Overview</label>
  <row>
    <panel>
      <title>Volumen de eventos por fuente - incidente CFP (picos de trafico)</title>
      <chart>
        <search>
          <query>index=proxylogon sourcetype IN (iis, windows_events_proxylogon) | timechart span=30m count by sourcetype</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Regla 1: SSRF Autodiscover Bypass</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=iis (cs_uri_stem="*autodiscover*" OR cs_uri_stem="*/ecp/*") (cs_uri_query="*@*" OR cs_Cookie="*X-AnonResource-Backend*" OR cs_Cookie="*X-BEResource*") | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Regla 3: C2 via Webshell</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=windows_events_proxylogon EventCode=4688 ParentProcessName="*w3wp.exe*" | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Regla 4: Exportacion de buzon</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=windows_events_proxylogon EventCode=4104 ScriptBlockText="*New-MailboxExportRequest*" | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Regla 5: Acceso a LSASS</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=windows_events_proxylogon EventCode=10 TargetProcessName="*lsass.exe*" | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <title>Falsos Positivos Regla 1 (debe ser 0)</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=iis c_ip="192.168.1.*" (cs_uri_stem="*autodiscover*" OR cs_uri_stem="*/ecp/*") (cs_uri_query="*@*" OR cs_Cookie="*X-AnonResource-Backend*" OR cs_Cookie="*X-BEResource*") | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
        <option name="rangeColors">["0x53a051","0xdc4e41"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Validacion contra dataset REAL (OTRF)</title>
      <single>
        <search>
          <query>index=proxylogon sourcetype=json_otrf_real EventID=1 ParentImage="*w3wp*" | stats count</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Top IPs origen (trafico IIS)</title>
      <table>
        <search>
          <query>index=proxylogon sourcetype=iis | top limit=10 c_ip</query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
      </table>
    </panel>
  </row>
</dashboard>
